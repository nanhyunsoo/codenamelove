# Supabase (Waitlist/Feedback 등에 사용)
# 아래 값을 실제 프로젝트 값으로 바꾼 뒤 .env.local 로 복사하세요.
# 프로젝트: https://supabase.com/dashboard → 프로젝트 선택 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 서버용 (API 라우트에서 사용, 없으면 ANON_KEY 사용)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 오픈그래프/트위터 카드용 사이트 주소 (배포 URL, 예: https://codename-love.vercel.app)
# 미설정 시 Vercel 배포에서는 VERCEL_URL 로 자동 설정됨
# NEXT_PUBLIC_APP_URL=https://your-domain.com
